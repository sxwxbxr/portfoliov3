# SMTP configuration for contact form emails
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM="Portfolio Contact <no-reply@example.com>"
CONTACT_RECIPIENT=your-destination@example.com

# NeonDB (serverless Postgres)
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# JWT Auth
JWT_SECRET=your-random-64-char-secret

# OpenRouter (powers all AI features — chat, contact analysis, deep dive, pitch, skill explorer)
OPENROUTER_API_KEY=sk-or-v1-...

# Vercel KV / Upstash Redis (durable global daily cap for the public AI routes).
# On Vercel, link a KV store and these are injected automatically. The code also
# accepts the UPSTASH_REDIS_REST_* equivalents. AI routes fail open if unset.
KV_REST_API_URL=https://your-store.kv.vercel-storage.com
KV_REST_API_TOKEN=your-kv-rest-token
